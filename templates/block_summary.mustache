{{!
    @template block_teacher_checklist/block_summary

    Displays the summary content inside the course block.

    @package    block_teacher_checklist
    @copyright  2026 Jean Lúcio
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "courseid": 2,
        "is_scan_active": true,
        "hasissues": true,
        "issues": [
            {
                "id": 1,
                "isdone": false,
                "bulkable": false,
                "number": 1,
                "icon": "i/course",
                "title": "Configure news forum",
                "url": "#",
                "severity_high": true,
                "can_mark_done": true,
                "can_restore": false,
                "can_ignore": true,
                "courseid": 2,
                "type": "auto",
                "subtype": "course",
                "docid": 0
            }
        ],
        "moreissues": {"count": 3},
        "fullreporturl": "#"
    }
}}
<div class="block-teacher-checklist-summary">
    <div class="d-flex align-items-center justify-content-between mb-3 form-switch">
        <label class="small text-muted mb-0 me-2" for="blockScanToggle">
            {{#str}} scan_enabled, block_teacher_checklist {{/str}}
        </label>
        <input class="form-check-input toggle-scan-switch m-0 position-static" type="checkbox" role="switch"
               id="blockScanToggle" data-courseid="{{courseid}}"
               {{#is_scan_active}}checked{{/is_scan_active}}>
    </div>
    
    <hr class="my-2">
    <div class="list-group list-group-flush mb-3 {{^hasissues}}d-none{{/hasissues}}" data-region="block-items-list">
        {{#issues}}
            {{> block_teacher_checklist/checklist_item }}
        {{/issues}}
    </div>

    {{#moreissues}}
    <div class="text-center small text-muted fst-italic mb-2" data-region="block-more-count" data-count="{{count}}">
        {{#str}} andmore, block_teacher_checklist, {{count}} {{/str}}
    </div>
    {{/moreissues}}

    <div class="alert alert-success d-flex align-items-center {{#hasissues}}d-none{{/hasissues}}" data-region="block-all-clear" role="alert">
        <i class="fa fa-check-circle fa-lg me-2" aria-hidden="true"></i>
        <div>{{#str}} no_issues_found, block_teacher_checklist {{/str}}</div>
    </div>

    <div class="text-center">
        <a href="{{fullreporturl}}" class="btn btn-primary btn-sm w-100">
            {{#str}} view_full_report, block_teacher_checklist {{/str}}
        </a>
    </div>
</div>
